{
  "name": "pipelineforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "bun run --watch src/backend/src/index.ts",
    "dev:frontend": "vite --config src/frontend/vite.config.ts",
    "dev:worker": "bun run --watch worker/src/index.ts",
    "worker": "bun run worker/src/index.ts",
    "build": "vite build --config src/frontend/vite.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun run src/backend/src/db/migrate.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.0",
    "@xyflow/react": "^12.11.2",
    "better-sqlite3": "^11.0.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.33.0",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.0",
    "lucide-react": "^0.400.0",
    "octokit": "^5.0.5",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "recharts": "^2.12.0",
    "tailwind-merge": "^2.5.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.24.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
